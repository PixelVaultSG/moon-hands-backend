# Moon Hands by Pixel Vault Pte Ltd - Environment Variables
# Copy this file to .env and fill in your values

# ─── TELEGRAM BOT ────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (the admin). Get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=your_telegram_user_id

# ─── SUPABASE ────────────────────────────────────────────────────
# From your Supabase project dashboard
SUPABASE_URL=https://sb_publishable_OoF9e2Q2i0KVWyksSPt8lw_y4sUHLzo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── VAPI.AI ─────────────────────────────────────────────────────
# From vapi.ai dashboard
VAPI_API_KEY=your_vapi_key_here

# ─── TWILIO ──────────────────────────────────────────────────────
# From twilio.com console
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+65xxxxxxxx

# ─── WHATSAPP (via Twilio) ──────────────────────────────────────
TWILIO_WHATSAPP_NUMBER=whatsapp:+65xxxxxxxx

# ─── META (Instagram/Facebook) ───────────────────────────────────
# From developers.facebook.com
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_access_token

# ─── OPENAI ──────────────────────────────────────────────────────
# From platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ─── GOOGLE CALENDAR ─────────────────────────────────────────────
# From console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
