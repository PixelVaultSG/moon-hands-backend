# Moon Hands by Pixel Vault Pte Ltd — Environment Variables
# Copy this file to .env and fill in your values

# ─── TELEGRAM BOT ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_telegram_user_id

# ─── SUPABASE ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── OPENAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ─── 360dialog WHATSAPP ──────────────────────────────────────────
DIALOG360_API_KEY=your_360dialog_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ─── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_KEY=your_webhook_api_key_here

# ─── WEBHOOK BASE URL ────────────────────────────────────────────
# Used to construct per-clinic webhook URLs
# Default: https://moon-hands-backend.onrender.com
WEBHOOK_BASE_URL=https://moon-hands-backend.onrender.com

# Note: Per-clinic authentication uses query parameters, not headers.
# Each clinic gets: /webhook/whatsapp?clinic_id=XXX&token=YYY
# No WEBHOOK_AUTH_REQUIRED or WEBHOOK_SECRET needed.

# ─── MONITORING & INTRUSION DETECTION ────────────────────────────
# Secret for registering your devices. Generate with: openssl rand -hex 32
MASTER_SECRET=generate_a_random_secret_here

# Secret for Kimi agent to identify itself. Generate with: openssl rand -hex 16
MOONHANDS_AGENT_SECRET=generate_another_random_secret_here

# Your registered device fingerprints (comma-separated)
# Get these by calling POST /api/register-device from each device
MASTER_DEVICE_FPS=

# ─── TELEGRAM NOTIFICATIONS ──────────────────────────────────────
TELEGRAM_ALERT_CHAT_ID=your_alert_channel_chat_id

# ─── CLINIC SCHEDULE (for closing summary notifications) ─────────
# Format: JSON object with day -> {open, close} in HH:MM format
# CLINIC_SCHEDULE={"mon":{"open":"09:00","close":"18:00"},...}

# ─── COST PROTECTION ─────────────────────────────────────────────
# Max daily WhatsApp message cost per clinic (in USD)
MAX_DAILY_COST_PER_CLINIC=5.00

# ─── OPTIONAL: Twilio (fallback voice/SMS) ───────────────────────
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+65xxxxxxxx

# ─── OPTIONAL: VAPI.AI (voice AI) ────────────────────────────────
# VAPI_API_KEY=your_vapi_key_here

# ─── OPTIONAL: Google Calendar ───────────────────────────────────
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── OPTIONAL: Meta (Instagram/Facebook) ─────────────────────────
# META_APP_ID=your_app_id
# META_APP_SECRET=your_app_secret
# META_ACCESS_TOKEN=your_access_token
